# =====================================================================
# Paperclip Holding — Production Environment Variables
# =====================================================================
# Bu dosyayı .env olarak kopyala, gerçek değerleri doldur, ASLA commit etme
# Railway'de bu değerler Dashboard → Variables sekmesinde tutulur
# =====================================================================

# Anthropic API key (kredi yüklü olsun — console.anthropic.com)
# Paperclip ajanları her heartbeat'te bu key ile claude'u çağırır
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-WITH-REAL-KEY

# Authentication secret (Railway için zorunlu)
# Yarat: openssl rand -hex 32
AUTH_SECRET=replace-with-32-byte-random-hex

# Database — local'de gömülü Postgres kullanır, prod'da Railway Postgres add-on
# Railway Postgres add-on bu env var'ı otomatik atar
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Network binding (lokal: loopback, prod: lan)
BIND=lan

# Allowed hostname for production (Railway domain)
# Railway → Settings → Networking → Public Domain
ALLOWED_HOSTNAME=paperclip-holding.up.railway.app

# Port (Railway otomatik atar, Paperclip okur)
# PORT=3100
